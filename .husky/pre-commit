#!/bin/sh

# Exit codes for better debugging
readonly EXIT_LINT_STAGED_FAILED=1
readonly EXIT_EXAMPLES_FAILED=2
readonly EXIT_VERSION_SYNC_FAILED=3

# Enable strict error handling
set -eu

# Main execution
main() {
    echo "🛡️ Running pre-commit checks..."

    # Run lint-staged (handles linting and formatting for staged files only)
    echo "🔍 Running lint-staged checks..."
    if ! npx lint-staged; then
        echo "❌ Lint-staged checks failed"
        exit $EXIT_LINT_STAGED_FAILED
    fi

    # Validate TypeScript examples
    echo "📚 Validating TypeScript examples..."
    if ! node scripts/validate-examples.js; then
        echo "❌ Examples validation failed"
        exit $EXIT_EXAMPLES_FAILED
    fi

    # Version sync guard — only when a version-carrying file is staged
    VERSION_FILES="package.json package-lock.json server.json CHANGELOG.md"
    STAGED=$(git diff --cached --name-only)
    VERSION_STAGED=false
    if [ -n "$STAGED" ]; then
        while IFS= read -r staged_path; do
            for f in $VERSION_FILES; do
                if [ "$staged_path" = "$f" ]; then
                    VERSION_STAGED=true
                    break 2
                fi
            done
        done <<EOF
$STAGED
EOF
    fi

    if [ "$VERSION_STAGED" = true ]; then
        echo "🔢 Validating version sync across carriers..."
        if ! npx tsx scripts/validate-version-sync.ts; then
            echo "❌ Version sync validation failed"
            exit $EXIT_VERSION_SYNC_FAILED
        fi
    fi

    echo "✅ Pre-commit checks passed!"
}

# Run main function
main "$@"